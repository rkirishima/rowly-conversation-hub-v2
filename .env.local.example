# ============================================
# Supabase Configuration
# ============================================
# Get these from: Supabase Dashboard → Settings → API

# Your Supabase project URL (e.g., https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ============================================
# OpenClaw API Configuration (Optional)
# ============================================
# Leave these commented out to use demo responses
# Uncomment when you have a real OpenClaw API endpoint

# NEXT_PUBLIC_OPENCLAW_API_URL=http://localhost:3000/api/ask-doug
# NEXT_PUBLIC_OPENCLAW_API_KEY=your-api-key

# ============================================
# App Configuration
# ============================================
NEXT_PUBLIC_APP_NAME=Rowly's Conversation Hub
